# Local deploy environment — copy to DEPLOY.env and fill in.
# Usage: set -a && source scripts/DEPLOY.env && set +a && ./scripts/deploy.sh

SSH_KEY_FILE=.deploy-keys/finance-deploy
DEPLOY_HOST=your-ssh-host-or-ip
DEPLOY_USER=vault-deploy
DEPLOY_APP_DIR=/path/to/app
DEPLOY_APP_OWNER=your-app-user
DEPLOY_STATIC_DIR=/var/www/vault/static
DEPLOY_SERVICE_NAME=vault
DEPLOY_CRON_NAME=vault
DEPLOY_CRON_LOG=/var/log/vault/cron.log
# DEPLOY_SSH_PORT=22
# DEPLOY_HEALTHCHECK_URL=https://your-site.example/
