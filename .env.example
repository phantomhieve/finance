# Django
DJANGO_SECRET_KEY=change-me-generate-with-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database (PostgreSQL in production; omit for SQLite dev)
# DATABASE_URL=postgres://vault_user:CHANGE_ME@localhost:5432/vault_db

# Public site URL (OAuth redirects, links)
VAULT_PUBLIC_URL=http://localhost:8000

# Google OAuth (django-allauth)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Google Sheets sync + GCS backups (service account JSON path)
GOOGLE_SHEETS_CREDENTIALS=credentials/google-service-account.json
# Alternative standard name (optional if GOOGLE_SHEETS_CREDENTIALS is set):
# GOOGLE_APPLICATION_CREDENTIALS=credentials/google-service-account.json

# GCS bucket for backup_db management command
BACKUP_GCS_BUCKET=your-gcs-bucket-name

# Multi-DB backup script (scripts/backup-all-dbs.sh)
BACKUP_SA_JSON_PATH=credentials/backup-sa.json
BACKUP_DATABASES=vault_db
BACKUP_LOG_FILE=/var/log/vault/backup.log
BACKUP_PYTHON=venv/bin/python3

# WebAuthn (Face ID / biometric unlock)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:8000

# Admin monitor health probe (optional; production)
# VAULT_HEALTH_CHECK_URL=http://127.0.0.1:80/login/
# VAULT_HEALTH_CHECK_HOST=finance.example.com

# Gemini AI insights
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-lite

# Gunicorn (production)
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_ACCESS_LOG=/var/log/vault/gunicorn-access.log
GUNICORN_ERROR_LOG=/var/log/vault/gunicorn-error.log
